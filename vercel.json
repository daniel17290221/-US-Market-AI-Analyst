{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python"
        }
    ],
    "rewrites": [
        {
            "source": "/api/acp",
            "destination": "api/index.py"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/(.*)",
            "destination": "api/index.py"
        }
    ],
    "ignoreCommand": "git diff --name-only HEAD^ HEAD | grep -qvE '^(KR_Market_Analyst/|us_market/.*\\.(json|csv|html)|vercel-trigger\\.txt)' || exit 0"
}