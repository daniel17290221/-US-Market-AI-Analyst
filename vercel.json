{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/acp",
            "destination": "/api/index.py"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.py"
        }
    ],
    "cleanUrls": true
}